{
  "name": "skjson-vsl",
  "version": "0.1.0",
  "description": "Framework-agnostic web components for visualizing skjson models",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "lint": "eslint src/ --ext .ts"
  },
  "peerDependencies": {
    "skjson-js": "^1.0.0"
  },
  "dependencies": {
    "lit": "^3.1.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "d3-scale": "^4.0.2",
    "d3-transition": "^3.0.1",
    "d3-ease": "^3.0.1"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1",
    "@types/d3-selection": "^3.0.10",
    "@types/d3-shape": "^3.1.6",
    "@types/d3-scale": "^4.0.8",
    "@types/d3-transition": "^3.0.8",
    "@types/d3-ease": "^3.0.2"
  },
  "author": "",
